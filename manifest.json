{
  "manifest_version": 3,
  "name": "Prompt Forge",
  "version": "1.1.0",
  "description": "Optimize your AI prompts using curated examples from prompts.chat",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://claude.ai/*",
        "https://gemini.google.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html",
  "permissions": ["storage"],
  "host_permissions": [
    "https://prompts.chat/*",
    "https://api.groq.com/*",
    "https://gemini.google.com/*"
  ]
}
